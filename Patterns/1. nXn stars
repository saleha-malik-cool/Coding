/*
Qustion:-
making pattern of nXn square :
for example 
n=4
****
****
****
****
*/
 
//Code:
#include <iostream>
using namespace std;

int main() {

    int n;
    cin >> n;

    int i = 1;

    while(i <= n) {

        int j = 1;

        while(j <= n) {
            cout << "*";
            j = j + 1;
        }

        cout << endl;
        i = i + 1;
    }

    return 0;
}
