#include <iostream>
#include <vector>
using namespace std;
vector<int> leader(vector<int>&arr){
    vector<int>ans;
    int n = arr.size();
    int max = arr[n-1];
    ans.push_back(arr[n-1]);
    for (int i =n-2; i>=0; i--){
        if(arr[i]>max){
            max = arr[i];
           ans.push_back(max);
           
        }
       
        

    }
    return ans ;
}
int main(){
    vector<int> arr={234,22,12,10,3,0,6};
    vector<int> ans = leader(arr);
    for(int i=0; i<ans.size(); i++){
        cout<<ans[i]<<" ";
    }

}
    
