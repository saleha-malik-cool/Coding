#include <iostream>
#include <vector>
using namespace std;

int twosum(vector<int>arr, int ans){
    int n =arr.size();
    int sum=0;
    for(int i=0; i<n; i++){
        for(int j =i+1; j<n; j++){
            sum=arr[j]+arr[i];
            if(sum==ans){
                return true;
            }
        }
    }
    return false;
}
int main(){
    vector<int>arr={2,6,5,8,11};
   if( twosum(arr,14)){
    cout<<"is present"<<endl;

   }
   else{
    cout<<"not present";
   }
}


#BETTER(OPTIMAL WHEN INDEX NEED TO PRINT)



#include <iostream>
#include <vector>
#include<unordered_map>
using namespace std;

vector<int> twosum(vector<int>&arr, int target){
   unordered_map <int,int>mpp;
    int n = arr.size();
    for(int i =0; i<n; i++){
        int complement= target - arr[i];
        if(mpp.find(complement)!=mpp.end()){
            return {mpp[complement],i};
        }
        mpp[arr[i]]=i;
    }
    return {};
}
int main(){
    vector<int>arr={2,6,5,8,11};
   vector<int>ans= twosum(arr,8);
   cout<<ans[0]<<" "<<ans[1];}



OPTIMAL



class Solution {
public:
    vector<int> twoSum(vector<int>& numbers, int target) {
        int n = numbers.size();
        int i =0;
        int j =n-1; 
        int sum=0;
         while(i<j){
            sum=numbers[i]+numbers[j];
            if(sum==target){
                return{i+1,j+1};
            }
            else if(sum>target){
                j--;

            }
            else{
                i++;
            }

         }
         return { };
        
    }
};
